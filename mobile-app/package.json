{
  "name": "mobile-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Expo mobile client for the MJD Football Scout player intelligence and recruitment platform.",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "deps:check": "expo install --check",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "^57.0.7",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "^57.0.3",
    "expo-router": "^57.0.7",
    "expo-splash-screen": "^57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@types/react": "~19.2.17",
    "jest": "29.7.0",
    "jest-expo": "^57.0.2",
    "typescript": "~6.0.3"
  },
  "private": true,
  "allowScripts": {
    "fsevents@2.3.3": true
  },
  "overrides": {
    "react-native-screens": "4.25.2"
  }
}
