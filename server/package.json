{
  "name": "mjd-football-scout-backend",
  "version": "2.0.0",
  "description": "Express and MongoDB API for the MJD Football Scout player intelligence and recruitment platform.",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "DOTENV_CONFIG_PATH=.env.development.local tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:express --external:cors --external:mongoose",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "start": "node dist/index.js"
  },
  "author": "Mahmoud Al Jarad",
  "license": "ISC",
  "dependencies": {
    "axios": "1.18.1",
    "bcryptjs": "3.0.3",
    "cheerio": "1.2.0",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.3.0",
    "iconv-lite": "0.7.2",
    "jsonwebtoken": "9.0.3",
    "mongodb": "7.0.0",
    "mongoose": "9.7.4",
    "stripe": "^22.3.2",
    "tsx": "4.23.1",
    "winston": "3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^7.0.2"
  },
  "dockerfile": {
    "secrets": [
      "MONGOURI"
    ]
  }
}
