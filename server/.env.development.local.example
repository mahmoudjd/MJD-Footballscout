NODE_ENV=development
PORT=8080
MONGOURI=mongodb://127.0.0.1:27017/MJD_FootballScout_Local
JWT_SECRET=replace-with-a-local-secret-at-least-32-characters
CLIENT_URL=http://localhost:3002
GOOGLE_CLIENT_ID=
PLAYERS_AUTO_UPDATE_ENABLED=false
PLAYERS_AUTO_UPDATE_INTERVAL_HOURS=12
PLAYERS_AUTO_UPDATE_RUN_ON_STARTUP=false
UPDATE_ALL_PLAYERS_CONCURRENCY=2
RESEND_API_KEY=
EMAIL_FROM=MJD Football Scout <noreply@example.com>
ONBOARDING_EMAILS_ENABLED=true
# Generate with: openssl rand -base64 32
MFA_ENCRYPTION_KEY=

# Stripe Billing (use test-mode keys and a recurring test Price ID locally)
PREMIUM_ENABLED=false
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me
