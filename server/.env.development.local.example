NODE_ENV=development
PORT=8080
MONGOURI=mongodb://127.0.0.1:27017/MJD_FootballScout_Local
JWT_SECRET=replace-with-a-local-secret-at-least-32-characters
CLIENT_URL=http://localhost:3002
GOOGLE_CLIENT_ID=
PLAYERS_AUTO_UPDATE_ENABLED=false
PLAYERS_AUTO_UPDATE_INTERVAL_HOURS=12
PLAYERS_AUTO_UPDATE_RUN_ON_STARTUP=false
UPDATE_ALL_PLAYERS_CONCURRENCY=2
RESEND_API_KEY=
# Sender for transactional/security emails. The domain (mjd-apps.com) must be
# verified in Resend (SPF/DKIM) before sends from this address succeed.
EMAIL_FROM=MJD Football Scout <info@mjd-apps.com>
ONBOARDING_EMAILS_ENABLED=true
# Generate with: openssl rand -base64 32
MFA_ENCRYPTION_KEY=
# Third player data source, used when BeSoccer and Playmakerstats come up empty.
# Leave blank to keep it disabled. Key from dashboard.api-football.com.
API_FOOTBALL_KEY=
# Only needed for the RapidAPI subscription; the direct api-sports endpoint is
# the default: https://api-football-v1.p.rapidapi.com/v3
API_FOOTBALL_BASE_URL=

